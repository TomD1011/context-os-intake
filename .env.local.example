# Context OS Intake — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; never commit secrets.

# ─── Anthropic ───────────────────────────────
# Required. https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Supabase (optional) ─────────────────────
# When both vars are set, the intake persists each session to Postgres so
# founders can refresh/resume via the ?session=<id> URL. When either var is
# missing, the app runs in memory-only mode and still works end-to-end — it
# just can't resume.
#
# Find these in Supabase dashboard → Project Settings → API.
# IMPORTANT: use the service_role key (not the anon key). It's server-only.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
